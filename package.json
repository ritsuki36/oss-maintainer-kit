{
  "name": "oss-maintainer-kit",
  "version": "0.2.0",
  "description": "A small CLI and template pack for OSS maintainer readiness checks and Codex for Open Source application drafts.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "templates",
    "examples"
  ],
  "bin": {
    "oss-maintainer-kit": "./bin/oss-maintainer-kit.mjs"
  },
  "scripts": {
    "check": "node bin/oss-maintainer-kit.mjs check",
    "demo": "node bin/oss-maintainer-kit.mjs application . --repo https://github.com/ritsuki36/oss-maintainer-kit --role \"core maintainer\"",
    "test": "node test/cli.test.mjs",
    "validate": "node --check bin/oss-maintainer-kit.mjs && node --check src/index.mjs && npm test && node bin/oss-maintainer-kit.mjs check ."
  },
  "keywords": [
    "oss",
    "open-source",
    "maintainer",
    "codex",
    "github"
  ],
  "author": "Ritsuki Yano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ritsuki36/oss-maintainer-kit.git"
  },
  "homepage": "https://github.com/ritsuki36/oss-maintainer-kit#readme",
  "bugs": {
    "url": "https://github.com/ritsuki36/oss-maintainer-kit/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
